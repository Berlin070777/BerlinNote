# BerlinNote local config
# Copy this file to .env and fill your own credentials. Do not commit .env.

TTS_PROVIDER=doubao

# New Doubao console, recommended by the V3 bidirectional WebSocket document.
DOUBAO_AUTH_MODE=api-key
DOUBAO_API_KEY=your_api_key

# Old Doubao console fallback. Use this only if you still have APP ID + Access Token.
# DOUBAO_AUTH_MODE=access-token
# DOUBAO_APP_ID=your_app_id
# DOUBAO_ACCESS_KEY=your_access_token
# DOUBAO_LEGACY_APP_HEADER=X-Api-App-Key
# If your console/document requires it, switch the previous line to:
# DOUBAO_LEGACY_APP_HEADER=X-Api-App-Id

DOUBAO_RESOURCE_ID=seed-tts-2.0
DOUBAO_VOICE_TYPE=zh_female_vv_uranus_bigtts
# AUDIO_CACHE_DIR=/absolute/path/to/audio-cache
# PORT=4173
